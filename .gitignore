# ============================================================================
# Numeraire++ — .gitignore
# ============================================================================

# --- Compiled artifacts -----------------------------------------------------
*.d
*.slo
*.lo
*.o
*.obj

*.gch
*.pch

*.ilk
*.pdb
*.dwo

*.so
*.dylib
*.dll

*.mod
*.smod

*.lai
*.la
*.a
*.lib

*.exe
*.out
*.app

# --- Build directories ------------------------------------------------------
build/
out/
cmake-build-*/

# --- CMake generated --------------------------------------------------------
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
Testing/
compile_commands.json

# --- Editor / IDE -----------------------------------------------------------
.idea/
**/.idea/
.cache/
.clangd/

# VS Code: track only what we want shared with the team
.vscode/*
!.vscode/launch.json
!.vscode/settings.json
!.vscode/extensions.json

# --- Environment / runtime --------------------------------------------------
.env
.envrc
logs/
data/

# --- macOS ------------------------------------------------------------------
.DS_Store

# --- Project notes / scratch ------------------------------------------------
CHECKLIST_NOTES.md
.cursor/plans

# --- DB---
db.sqlite3
*.session.sql
refactor.sql

# --- cached data ---
cached_market_data

# --- Trade bundle drafts (samples stay committed) ---
trades/incoming/*.json
!trades/incoming/trade_bundle.sample.json
!trades/incoming/trade_bundle_binary.sample.json
!trades/incoming/trade_bundle_forward.sample.json


# --- python ---
__pycache__/
*.py[cod]
*$py.class
.venv-viz/
.ipynb_checkpoints/
viz/**/.ipynb_checkpoints/
