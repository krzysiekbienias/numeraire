# ============================================================================
# Numeraire++ — environment template
#
# Copy to `.env` (already gitignored) and adjust values for your local setup.
# Loaded at runtime by numeraire::utils::EnvLoader (Sprint 2+).
# Real env vars (`export FOO=bar`) override values from this file.
# ============================================================================

# --- Logging ----------------------------------------------------------------
# Levels: trace | debug | info | warn | error | critical (no inline comments on value lines — EnvLoader keeps text after '=' as-is)
NUMERAIRE_LOG_LEVEL=info
NUMERAIRE_LOG_FILE=logs/numeraire.log

# --- Database (Stage 2+) ----------------------------------------------------
# Default local file at repo root (see .gitignore `db.sqlite3`); overrides configs/default.json database.path when set.
NUMERAIRE_DB_PATH=db.sqlite3

# --- Market data providers (Stage 3+) ---------------------------------------
# POLYGON_API_KEY=
# POLYGON_BASE_URL=https://api.polygon.io

# --- dev_main sandbox — price one trade from SQLite -----------------------------
# Used when `./build/dev_main` is launched without a positional trade_id argument.
NUMERAIRE_DEV_TRADE_ID=TRD_001

# Synthetic BS inputs (underlying id comes from the loaded trade row).
NUMERAIRE_DEV_SPOT=240
NUMERAIRE_DEV_RATE=0.03
NUMERAIRE_DEV_VOL=0.20
NUMERAIRE_DEV_DIV_YIELD=0
